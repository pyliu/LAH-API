# ==========================================
# Print Server Monitor 外部設定檔 (Printer_API_Agent.env)
# 支援型別：字串、數字、布林值(true/false)、陣列(以逗號分隔)
# ==========================================

# --- 1. 核心網路與 API 設定 ---
PORT=8888
API_KEY=YourSecretApiKey123

# --- 2. 系統路徑設定 ---
LOG_PATH=C:\Temp
UPLOAD_PATH=C:\Temp\Uploads
MAX_LOG_SIZE_BYTES=10485760
MAX_HISTORY=5
LOG_RETENTION_DAYS=7
PRINT_LOG_FILE_PATH=C:\printlog

# PDF 閱讀器路徑 (多組請用逗號 , 分隔)
PDF_READER_PATHS=C:\Program Files (x86)\Foxit Software\Foxit PDF Reader\FoxitPDFReader.exe, C:\Program Files\Foxit Software\Foxit PDF Reader\FoxitPDFReader.exe, C:\FoxitReader\Foxit Reader.exe, C:\Program Files\Adobe\Acrobat DC\Acrobat\Acrobat.exe, C:\Program Files (x86)\Adobe\Acrobat Reader DC\Reader\AcroRd32.exe

# --- 3. 網路磁碟機 (UNC) 認證對應 ---
ENABLE_DRIVE_MAPPING=true
MAPPED_DRIVE_LETTER=Z:
MAPPED_DRIVE_UNC_PATH=\\220.1.34.43\land_adm_web_ha\cer
NETWORK_USERNAME=
NETWORK_PASSWORD=

# --- 4. 通知伺服器設定 ---
NOTIFY_IP=220.1.34.75
NOTIFY_PORT=80
NOTIFY_ENDPOINT=/api/notification_json_api.php
NOTIFY_CHANNELS=HAXXXXXXXX
ENABLE_NOTIFY_HEALTH_CHECK=true
NOTIFY_TIMEOUT_MS=1000
ENABLE_ADMIN_NOTIFICATIONS=false

# --- 5. 監控與自癒觸發條件 ---
CHECK_INTERVAL_SEC=60
ERROR_THRESHOLD=5
MONITOR_START_HOUR=8
MONITOR_END_HOUR=17
MONITOR_DAYS=Monday, Tuesday, Wednesday, Thursday, Friday

ENABLE_AUTO_CLEANUP=true
ZOMBIE_TIME_MINUTES=10
ENABLE_AUTO_HEAL=true
MAX_STUCK_PRINTERS=3
ENABLE_SCHEDULED_HEAL=true
SCHEDULED_HEAL_CRON=30 7 * * *
QUEUE_THRESHOLD=20
QUEUE_STUCK_LIMIT=5

# --- 6. 排除項目 (以逗號分隔) ---
EXCLUDE_KEYWORDS=PDF, XPS, Fax, OneNote, Microsoft Shared Fax, Z_PRINT(空白)
MANUAL_EXCLUDE_PRINTERS=範例印表機名稱_A, 範例印表機名稱_B