# ==========================================
# Tomcat API Agent 設定檔
# ==========================================

# ------------------------------------------
# 1. 網路與安全設定
# ------------------------------------------
# API 監聽連接埠 (預設: 18888)
PORT=18888

# API 授權金鑰 (請務必更改為強密碼，前端面板需輸入此金鑰)
API_KEY="TomcatSecretKey123!"

# ------------------------------------------
# 2. Tomcat 環境設定
# ------------------------------------------
# Tomcat Windows 服務名稱 (可在 services.msc 中查看)
TOMCAT_SERVICE_NAME="Apache Tomcat 7.0 Tomcat7"

# Tomcat 安裝根目錄 (用於定位 logs 與清理 work/temp 目錄)
TOMCAT_DIR="C:\Tomcat 7.0"

# ------------------------------------------
# 3. 日誌管理設定 (Agent 自身日誌)
# ------------------------------------------
# API Agent 自身日誌存放路徑
LOG_PATH="C:\Temp\TomcatApiLogs"

# 單一檔案最大容量限制 (預設 10MB = 10485760 Bytes)
MAX_LOG_SIZE_BYTES=10485760

# 歷史日誌保留份數 (滾動覆蓋)
MAX_HISTORY=5

# 舊日誌與打包壓縮檔保留天數
LOG_RETENTION_DAYS=7

# ------------------------------------------
# 4. 自動排程維護設定
# ------------------------------------------
# 是否啟用自動定時重啟服務與清理快取 (true/false)
ENABLE_SCHEDULED_RESTART=true

# 排程執行時間的 Cron 表達式
# 格式: 分 時 日 月 星期 (預設 "30 7 * * *" 為每天早上 07:30 執行)
SCHEDULED_RESTART_CRON="30 7 * * *"

# ------------------------------------------
# 5. 系統通知設定 (第三方推播 API)
# ------------------------------------------
# 是否啟用管理員重要操作通知發送 (true/false)
ENABLE_ADMIN_NOTIFICATIONS=true

# 通知伺服器 IP 位址
NOTIFY_IP="220.1.34.75"

# 通知伺服器 Port
NOTIFY_PORT=80

# 通知伺服器 API 接收端點
NOTIFY_ENDPOINT="/api/notification_json_api.php"

# 通知發送目標頻道 (若有多個頻道請用逗號 , 分隔)
NOTIFY_CHANNELS="val"

# ------------------------------------------
# 6. 通知伺服器健康檢查
# ------------------------------------------
# 啟動時是否檢查通知伺服器存活狀態 (若離線則暫停發送避免阻塞)
ENABLE_NOTIFY_HEALTH_CHECK=true

# 檢查連線逾時時間 (毫秒)
NOTIFY_TIMEOUT_MS=1000

# ------------------------------------------
# 7. 服務健康檢查
# ------------------------------------------
# 啟動時是否檢查服務存活狀態
WATCH_AUTO_SERVICES=true

# 檢查服務的名稱(逗號分隔)
WATCH_AUTO_SERVICE_NAMES=MSSQLSERVER

# 檢查連線逾時時間 (秒)
WATCH_AUTO_SERVICE_INTERVAL_SEC=60
